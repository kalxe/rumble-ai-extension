{
  "manifest_version": 3,
  "name": "Rumble Auto-Tip",
  "version": "1.0.0",
  "description": "Automatically tip Rumble creators based on watch time. Powered by Tether WDK.",

  "permissions": [
    "storage",
    "activeTab",
    "alarms"
  ],

  "host_permissions": [
    "https://rumble.com/*",
    "https://*.rumble.com/*"
  ],

  "background": {
    "service_worker": "dist/background.bundle.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["https://rumble.com/*", "https://*.rumble.com/*"],
      "js": ["dist/content.bundle.js"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "web_accessible_resources": [
    {
      "resources": ["icons/*"],
      "matches": ["https://rumble.com/*"]
    }
  ]
}
